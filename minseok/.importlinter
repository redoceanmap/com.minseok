# =============================================================================
# import-linter — minseok 백엔드 아키텍처 하네스 (코드 레벨)
# =============================================================================
# 왜 필요한가 (카파시式 하네스):
#   minseok는 모듈러 모놀리식이며 두 개의 직교하는 구조 규칙을 동시에 가진다.
#     (1) 앱 '내부'  — 헥사고날/클린: adapter → app → domain (역방향 금지)
#     (2) 앱 '사이'  — 스타 토폴로지: star_craft(허브) 중심, 스포크끼리 직접 참조 금지
#   사람 리뷰는 이 규칙을 놓친다. import-linter가 실제 import 그래프를 정적 분석해
#   규칙 위반을 '테스트'처럼 실패로 만든다. 비선형 연결이 메시로 무너지지 않도록
#   배선(harness)을 고정하는 장치다.
#
# 실행:
#   cd minseok && PYTHONPATH=apps lint-imports --config .importlinter
#   (apps/ 를 경로에 올려야 titanic·lion_king 등이 최상위 패키지로 보인다.
#    main.py 의 sys.path.insert(0, "apps") 와 동일한 맥락.)
#
# 설치:  pip install import-linter   (minseok/requirements.txt 에 포함)
# =============================================================================

[importlinter]
root_packages =
    star_craft
    titanic
    sherlock_homes
    lion_king
    silicon_valley
    kingsman
    avengers
    jobs

# -----------------------------------------------------------------------------
# 계약 1) 클린 아키텍처 — 모든 앱 내부에서 adapter > app > domain
# -----------------------------------------------------------------------------
# layers 는 위에서 아래로 '상위 → 하위'. 상위는 하위를 import 할 수 있고,
# 하위는 상위를 import 할 수 없다.
#   adapter  : 인바운드/아웃바운드 어댑터 (최상위)
#   app      : use_cases·ports·dtos
#   domain   : 순수 엔티티·값객체 (최하위, 외부 의존 0)
# containers 로 7개 앱 모두에 동일 규칙을 한 번에 적용한다.
# (dependencies/ 같은 합성 루트는 어느 레이어에도 속하지 않으므로 이 계약의 제약을
#  받지 않는다 — DI 와이어링이 전 계층을 아는 것은 허용.)
[importlinter:contract:clean-architecture]
name = 클린 아키텍처 계층 (adapter > app > domain) — 전 앱 공통
type = layers
layers =
    adapter
    app
    domain
containers =
    titanic
    sherlock_homes
    lion_king
    silicon_valley
    kingsman
    avengers
    jobs

# -----------------------------------------------------------------------------
# 계약 2) 스타 토폴로지 — 스포크는 서로를 import 하지 않는다
# -----------------------------------------------------------------------------
# independence: 아래 모듈들은 (어느 방향으로도) 서로를 import 할 수 없다.
# 스포크 간 직접 참조·순환 참조를 원천 차단한다. 교차 도메인 협력이 필요하면
# 허브(star_craft)를 경유해야 한다.  (허브는 이 목록에서 제외 — 스포크→허브는 허용.)
[importlinter:contract:spoke-independence]
name = 스포크 상호 독립 (스포크 ↔ 스포크 직접 참조 금지)
type = independence
modules =
    titanic
    sherlock_homes
    lion_king
    silicon_valley
    kingsman
    avengers
    jobs

# -----------------------------------------------------------------------------
# 계약 3) 허브 격리 — 허브(star_craft)는 스포크에 의존하지 않는다
# -----------------------------------------------------------------------------
# 허브가 특정 스포크를 알게 되면 허브가 비대해지고 스타가 메시로 무너진다.
# 허브는 스포크의 '추상(포트/DTO)'만 알아야 하며 구체 스포크 패키지를 import 하지 않는다.
# (현재 star_craft 는 비어 있어 자동 통과 — 미래의 회귀를 막는 가드.)
[importlinter:contract:hub-isolation]
name = 허브 격리 (star_craft → 스포크 import 금지)
type = forbidden
source_modules =
    star_craft
forbidden_modules =
    titanic
    sherlock_homes
    lion_king
    silicon_valley
    kingsman
    avengers
    jobs
